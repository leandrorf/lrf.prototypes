@{
    ViewData["Title"] = "Demo Device Authorization (TV)";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card">
    <h2>📺 Demo Device Authorization (simulação de TV)</h2>

    <p style="margin-bottom: 20px; color: #555;">
        Esta página simula uma TV/dispositivo que usa o fluxo de <strong>Device Authorization</strong>.
        Ela chama o endpoint <code>/oauth/device_authorization</code>, exibe o <strong>user_code</strong>
        e o <strong>QRCode</strong> para você testar o fluxo completo.
    </p>

    <form id="device-form" style="margin-bottom: 20px;">
        <div class="form-group">
            <label for="client_id">Client ID</label>
            <input type="text"
                   id="client_id"
                   name="client_id"
                   value="demo-spa"
                   style="width: 100%;" />
        </div>

        <div class="form-group">
            <label for="scope">Escopos</label>
            <input type="text"
                   id="scope"
                   name="scope"
                   value="openid profile offline_access"
                   style="width: 100%;" />
        </div>

        <button type="submit" class="btn">
            🎬 Gerar código de dispositivo
        </button>
    </form>

    <div id="result" style="display: none; margin-top: 20px;">
        <div class="client-info">
            <h3>📟 Código para digitar</h3>
            <p style="font-size: 1.6rem; font-weight: 700; letter-spacing: 4px; margin-top: 10px;">
                <span id="user_code_value"></span>
            </p>
            <p style="margin-top: 10px;">
                Peça para o usuário acessar:
                <code id="verification_uri_value"></code>
            </p>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 20px; margin-top: 20px; align-items: center;">
            <div>
                <h3>📷 QRCode</h3>
                <img id="qr_image"
                     alt="QRCode para ativação"
                     style="width: 220px; height: 220px; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.15);" />
            </div>

            <div style="flex: 1; min-width: 240px;">
                <h3>🔗 Links gerados</h3>
                <p style="font-size: 14px; word-break: break-all;">
                    <strong>verification_uri_complete:</strong><br />
                    <code id="verification_uri_complete_value"></code>
                </p>
                <p style="font-size: 14px; word-break: break-all; margin-top: 10px;">
                    <strong>verification_qr_uri:</strong><br />
                    <code id="verification_qr_uri_value"></code>
                </p>
            </div>
        </div>

        <div style="margin-top: 25px; padding: 15px; background: #f8f9fa; border-radius: 8px;">
            <h4 style="margin-bottom: 10px;">🧪 Como testar o fluxo completo</h4>
            <ol style="margin-left: 18px; color: #555; font-size: 14px;">
                <li>Abra o link em <strong>verification_uri_complete</strong> em outro navegador/aba (lado usuário).</li>
                <li>Faça login se necessário e autorize o dispositivo.</li>
                <li>No Swagger/Postman, faça <code>POST /oauth/token</code> com
                    <code>grant_type=urn:ietf:params:oauth:grant-type:device_code</code>
                    e o <code>device_code</code> retornado (simulando o polling da TV).</li>
            </ol>
        </div>

        <div style="margin-top: 20px;">
            <details>
                <summary style="cursor: pointer; color: #0069d9;">Ver resposta JSON bruta</summary>
                <pre id="raw_json" style="margin-top: 10px; background: #212529; color: #f8f9fa; padding: 10px; border-radius: 6px; font-size: 12px; overflow-x: auto;"></pre>
            </details>
        </div>
    </div>

    <div id="error" class="alert alert-error" style="display: none; margin-top: 20px;"></div>
</div>

<script>
    (function () {
        const form = document.getElementById('device-form');
        const result = document.getElementById('result');
        const errorBox = document.getElementById('error');

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            errorBox.style.display = 'none';
            result.style.display = 'none';

            const clientId = document.getElementById('client_id').value.trim();
            const scope = document.getElementById('scope').value.trim();

            const body = new URLSearchParams();
            body.append('client_id', clientId);
            if (scope) {
                body.append('scope', scope);
            }

            try {
                const response = await fetch('/oauth/device_authorization', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: body.toString()
                });

                if (!response.ok) {
                    const text = await response.text();
                    throw new Error(text || ('Erro HTTP ' + response.status));
                }

                const data = await response.json();

                document.getElementById('user_code_value').textContent = data.user_code || '';
                document.getElementById('verification_uri_value').textContent = data.verification_uri || '';
                document.getElementById('verification_uri_complete_value').textContent = data.verification_uri_complete || '';
                document.getElementById('verification_qr_uri_value').textContent = data.verification_qr_uri || '';

                const qrImg = document.getElementById('qr_image');
                if (data.verification_qr_uri) {
                    qrImg.src = data.verification_qr_uri;
                    qrImg.style.display = 'block';
                } else {
                    qrImg.style.display = 'none';
                }

                document.getElementById('raw_json').textContent = JSON.stringify(data, null, 2);

                result.style.display = 'block';
            } catch (err) {
                errorBox.textContent = 'Erro ao chamar /oauth/device_authorization: ' + (err.message || err);
                errorBox.style.display = 'block';
            }
        });
    })();
</script>

